# Byte-compiled / cache
__pycache__/
*.py[cod]
*.pyo
.mypy_cache/
.pytest_cache/

# Virtual environments
venv/
.venv/
env/

# Streamlit
.streamlit/secrets.toml

# Model weights (large binary files - auto-downloaded on first run)
models/*.pt
models/*.onnx

# Generated video outputs
videos/outputs/*
!videos/outputs/.gitkeep

# Generated reports
reports/*.csv
reports/*.pdf
!reports/.gitkeep

# Uploaded / temp files
*.tmp
temp/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Logs
*.log
